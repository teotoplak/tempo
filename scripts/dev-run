#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOG_PATH="${TEMPO_DEV_LOG_PATH:-/tmp/tempo-dev-run.log}"
PID_PATH="${TEMPO_DEV_PID_PATH:-/tmp/tempo-dev-run.pid}"
LAUNCH_LABEL="${TEMPO_DEV_LAUNCH_LABEL:-com.tempo.dev-run}"

cd "$ROOT_DIR"

swift build

APP_BIN="$(swift build --show-bin-path)/TempoApp"

launchctl remove "$LAUNCH_LABEL" >/dev/null 2>&1 || true
existing_pids="$(pgrep -x TempoApp || true)"
debugserver_pids=""

while read -r pid; do
  [[ -n "$pid" ]] || continue
  parent_pid="$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
  if [[ -n "$parent_pid" ]] && ps -p "$parent_pid" -o args= 2>/dev/null | grep -q '/debugserver'; then
    debugserver_pids="$debugserver_pids $parent_pid"
  fi
done <<<"$existing_pids"

if [[ -n "$existing_pids" ]]; then
  osascript -e 'tell application "TempoApp" to quit' >/dev/null 2>&1 || true

  for _ in {1..25}; do
    if ! pgrep -x TempoApp >/dev/null; then
      break
    fi
    sleep 0.2
  done

  existing_pids="$(pgrep -x TempoApp || true)"
  if [[ -n "$debugserver_pids" ]]; then
    kill -TERM $debugserver_pids >/dev/null 2>&1 || true
  fi
  if [[ -n "$existing_pids" ]]; then
    kill -TERM $existing_pids >/dev/null 2>&1 || true
  fi

  for _ in {1..25}; do
    if ! pgrep -x TempoApp >/dev/null; then
      break
    fi
    sleep 0.2
  done

  existing_pids="$(pgrep -x TempoApp || true)"
  if [[ -n "$debugserver_pids" ]]; then
    kill -KILL $debugserver_pids >/dev/null 2>&1 || true
  fi
  if [[ -n "$existing_pids" ]]; then
    kill -KILL $existing_pids >/dev/null 2>&1 || true
  fi
fi

# Wrap the built binary in a minimal .app bundle. The SwiftUI MenuBarExtra
# window (.menuBarExtraStyle(.window)) is only hosted correctly when the
# process runs from a real bundle with a bundle identifier and LSUIElement;
# launching the bare executable renders the menu-bar popover empty. The bundle
# lives inside the gitignored .build dir and is a dev-only relaunch artifact,
# not a persistent install.
APP_BUNDLE="$(swift build --show-bin-path)/Tempo.app"

rm -rf "$APP_BUNDLE"
mkdir -p "$APP_BUNDLE/Contents/MacOS" "$APP_BUNDLE/Contents/Resources"
cp "$APP_BIN" "$APP_BUNDLE/Contents/MacOS/TempoApp"

cat >"$APP_BUNDLE/Contents/Info.plist" <<'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Tempo</string>
    <key>CFBundleDisplayName</key>
    <string>Tempo</string>
    <key>CFBundleExecutable</key>
    <string>TempoApp</string>
    <key>CFBundleIdentifier</key>
    <string>com.tempo.dev</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>15.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>Local dev build</string>
</dict>
</plist>
PLIST

codesign --force --sign - "$APP_BUNDLE" >/dev/null 2>&1 || true

open "$APP_BUNDLE"
sleep 1

started_pids="$(pgrep -x TempoApp || true)"
if [[ -z "$started_pids" ]]; then
  echo "TempoApp did not stay running." >&2
  exit 1
fi

printf '%s\n' "$started_pids" | head -n 1 >"$PID_PATH"

echo "TempoApp started with pid $(cat "$PID_PATH")"
echo "Bundle: $APP_BUNDLE"
